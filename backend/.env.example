# Application
APP_NAME="SentinelAI"
DEBUG=true
API_V1_PREFIX=/api/v1
SECRET_KEY=change-this-to-a-secure-random-key
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Zoho Catalyst
CATALYST_PROJECT_ID=your_catalyst_project_id
CATALYST_CLIENT_ID=your_catalyst_client_id
CATALYST_CLIENT_SECRET=your_catalyst_client_secret
CATALYST_REFRESH_TOKEN=your_catalyst_refresh_token
CATALYST_REGION=us_west

# Catalyst DataStore (PostgreSQL)
CATALYST_DATABASE_KEY=sentinelai_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=sentinelai
POSTGRES_USER=sentinelai
POSTGRES_PASSWORD=sentinelai_pass

# Neo4j Aura
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# Qdrant Cloud
QDRANT_HOST=your-instance.cloud.qdrant.io
QDRANT_PORT=6333
QDRANT_API_KEY=your_qdrant_api_key

# Redis
REDIS_HOST=your-redis-instance.cloud
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# OpenAI / Groq (use Groq for free fast inference)
OPENAI_API_KEY=gsk_your-groq-api-key
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Sentence Transformers
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Mapbox
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
